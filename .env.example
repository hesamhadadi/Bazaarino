# ---------- Core ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-32-chars-min
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database ----------
MONGODB_URI=mongodb://127.0.0.1:27017/bazaarino

# ---------- Google OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- SMTP (for email + OTP fallback) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bazaarino <no-reply@bazaarino.online>"

# ---------- Telegram Gateway OTP (free for Telegram users) ----------
# Get your token from https://gateway.telegram.org/ (log in with Telegram)
TELEGRAM_GATEWAY_TOKEN=

# Set to "true" in local dev to print OTP codes in server logs (never set in prod).
OTP_DEV_MODE=false

# ---------- Telegram bot (existing features) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ---------- Uploads / Storage ----------
UPLOAD_DIR=./public/uploads

# ---------- Push notifications (VAPID) ----------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bazaarino.online
