# ---------- Core ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-32-chars-min
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Database ----------
MONGODB_URI=mongodb://127.0.0.1:27017/bazaarino

# ---------- Google OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- SMTP (for email + OTP fallback) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bazaarino <no-reply@bazaarino.online>"

# ---------- Telegram Gateway OTP (free for Telegram users) ----------
# Get your token from https://gateway.telegram.org/ (log in with Telegram)
TELEGRAM_GATEWAY_TOKEN=

# Set to "true" in local dev to print OTP codes in server logs (never set in prod).
OTP_DEV_MODE=false

# ---------- Telegram bot (existing features) ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ---------- Uploads / Storage ----------
UPLOAD_DIR=./public/uploads

# ---------- Push notifications (VAPID) ----------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bazaarino.online

# ---------- Analytics & SEO (all optional) ----------
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token (from "HTML tag" verification method)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools (optional)
NEXT_PUBLIC_BING_SITE_VERIFICATION=
# Yandex Webmaster (optional)
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=

# ---------- Sentry error tracking (optional) ----------
# DSN is exposed to the browser; safe to share publicly per Sentry docs
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only required to upload source maps during build for clean stacktraces
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# ---------- AI (Gemini) for ad title/description generator ----------
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=
